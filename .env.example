DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/DB?sslmode=require"
NEON_SCHEMA="open_stock_hub"

# Snowflake remains the system of truth. Neon stores app cache, audit, and workflow state.
SNOWFLAKE_ACCOUNT=""
SNOWFLAKE_USERNAME=""
SNOWFLAKE_PASSWORD=""
# Use either SNOWFLAKE_PASSWORD or one private-key option.
SNOWFLAKE_PRIVATE_KEY=""
SNOWFLAKE_PRIVATE_KEY_BASE64=""
SNOWFLAKE_PRIVATE_KEY_PATH=""
SNOWFLAKE_PRIVATE_KEY_PASSPHRASE=""
SNOWFLAKE_WAREHOUSE=""
SNOWFLAKE_DATABASE="FOODBUY_MASALA_PROD"
SNOWFLAKE_DB="FOODBUY_MASALA_PROD"
SNOWFLAKE_SCHEMA="COMPLIANCE_LAB"
SNOWFLAKE_ROLE=""
SNOWFLAKE_AUTHENTICATOR=""
SNOWFLAKE_OAUTH_TOKEN=""
SNOWFLAKE_CLIENT_STORE_TEMPORARY_CREDENTIAL="false"
# Local desktop SSO can use EXTERNALBROWSER, but Vercel needs non-interactive auth:
# set SNOWFLAKE_PASSWORD, SNOWFLAKE_PRIVATE_KEY_BASE64, or SNOWFLAKE_OAUTH_TOKEN.

# Set this for server-to-server sync calls. Leave ALLOW_UI_SYNC off unless the app is private.
SYNC_API_KEY=""
ALLOW_UI_SYNC="false"

# Optional OIDC auth for Vercel and the local preview server.
# Leave AUTH_REQUIRED=false for unauthenticated local development.
AUTH_REQUIRED="false"
AUTH_BYPASS_TOKEN=""
OIDC_AUTHORITY=""
OIDC_AUTHORIZE_URL=""
OIDC_CLIENT_ID=""
OIDC_CLIENT_SECRET=""
OIDC_REDIRECT_URI=""
# Optional local-only callback when Vercel and localhost use different registered redirect URLs.
OIDC_LOCAL_REDIRECT_URI=""
OIDC_TOKEN_PATH="/token"
OIDC_PROFILE_PATH="/profile"
OIDC_LOGOUT_URL=""

# Optional runtime behavior.
HUB_QUERY_MODE="snowflake"
OPENSTOCK_SNOWFLAKE_WRITES="true"
